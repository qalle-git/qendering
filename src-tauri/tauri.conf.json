{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qendering",
  "version": "0.16.0",
  "identifier": "dev.qalle.qendering",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Qendering",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../python/blender_render.py": "python/blender_render.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2MjYyNkJDMTk2REUxNkIKUldScjRXMFp2Q1ltbG5OMFJrR3A2Um9WQkx2dStyQ2V4RnZmeCtDdm40YlBnQVZnU3kvNk1hYnAK",
      "endpoints": [
        "https://github.com/qalle-git/qendering/releases/latest/download/latest.json"
      ]
    }
  }
}
